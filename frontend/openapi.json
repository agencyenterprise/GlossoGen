{
  "openapi": "3.1.0",
  "info": {
    "title": "Schmidt Simulation Server",
    "version": "0.1.0"
  },
  "paths": {
    "/api/runs": {
      "get": {
        "summary": "List Runs",
        "description": "List all discovered simulation runs.",
        "operationId": "list_runs_api_runs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/runs/{run_id}": {
      "get": {
        "summary": "Get Run Detail",
        "description": "Get full detail for a specific simulation run.",
        "operationId": "get_run_detail_api_runs__run_id__get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunDetailResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Run",
        "description": "Delete a simulation run and all its files.",
        "operationId": "delete_run_api_runs__run_id__delete",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/runs/{run_id}/stop": {
      "post": {
        "summary": "Stop Run",
        "description": "Stop a running simulation by sending SIGTERM to its process.",
        "operationId": "stop_run_api_runs__run_id__stop_post",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/runs/{run_id}/events": {
      "get": {
        "summary": "Stream Run Events",
        "description": "Stream simulation events as Server-Sent Events.\n\nOnly available for live simulations (detected via stream.json manifest).\nProxies SSE from the simulation's embedded server. Returns 404 if the\nrun is not found, and 409 if the simulation is not currently running.\n\nThe SSE ``data`` field of each frame contains a JSON object conforming to\none of the SSEEvent union members, discriminated by the ``event_type`` field.",
        "operationId": "stream_run_events_api_runs__run_id__events_get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE event stream. Each SSE frame has an `event` field matching the event_type discriminator and a `data` field containing the JSON payload.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SSESimulationStarted"
                    },
                    {
                      "$ref": "#/components/schemas/SSEAgentRegistered"
                    },
                    {
                      "$ref": "#/components/schemas/SSEAgentConnected"
                    },
                    {
                      "$ref": "#/components/schemas/SSEMessageSent"
                    },
                    {
                      "$ref": "#/components/schemas/SSELLMResponseReceived"
                    },
                    {
                      "$ref": "#/components/schemas/SSEToolResultReceived"
                    },
                    {
                      "$ref": "#/components/schemas/SSERoundAdvanced"
                    },
                    {
                      "$ref": "#/components/schemas/SSEInjectionDelivered"
                    },
                    {
                      "$ref": "#/components/schemas/SSESimulationEnded"
                    },
                    {
                      "$ref": "#/components/schemas/SSETokenDelta"
                    },
                    {
                      "$ref": "#/components/schemas/SSEMessagePreview"
                    },
                    {
                      "$ref": "#/components/schemas/SSEDebugLog"
                    }
                  ],
                  "discriminator": {
                    "propertyName": "event_type",
                    "mapping": {
                      "simulation_started": "#/components/schemas/SSESimulationStarted",
                      "agent_registered": "#/components/schemas/SSEAgentRegistered",
                      "agent_connected": "#/components/schemas/SSEAgentConnected",
                      "message_sent": "#/components/schemas/SSEMessageSent",
                      "llm_response_received": "#/components/schemas/SSELLMResponseReceived",
                      "tool_result_received": "#/components/schemas/SSEToolResultReceived",
                      "round_advanced": "#/components/schemas/SSERoundAdvanced",
                      "injection_delivered": "#/components/schemas/SSEInjectionDelivered",
                      "simulation_ended": "#/components/schemas/SSESimulationEnded",
                      "token_delta": "#/components/schemas/SSETokenDelta",
                      "message_preview": "#/components/schemas/SSEMessagePreview",
                      "debug_log": "#/components/schemas/SSEDebugLog"
                    }
                  },
                  "title": "Response 200 Stream Run Events Api Runs  Run Id  Events Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/runs/{run_id}/fork": {
      "post": {
        "summary": "Fork Run",
        "description": "Create a forked simulation run from a specific message.\n\nTruncates the source event log at the target message, applies text edits,\nwrites the result to a new run directory, and launches the simulation as\na background subprocess.",
        "operationId": "fork_run_api_runs__run_id__fork_post",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForkRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForkResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/runs/{run_id}/export/pdf": {
      "get": {
        "summary": "Export Run Pdf",
        "description": "Export a simulation run as a formatted PDF document.\n\nGenerates a PDF containing messages, reasoning, and tool calls\ngrouped by round and turn. Optionally filters to a single channel.",
        "operationId": "export_run_pdf_api_runs__run_id__export_pdf_get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          },
          {
            "name": "channel_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Channel Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PDF document of the simulation run.",
            "content": {
              "application/json": {
                "schema": {}
              },
              "application/pdf": {}
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
