# LLM provider keys (at least one required for running simulations)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local inference configuration. See docs/local-inference-vllm-mlx.md for setup instructions.
# OPENAI_BASE_URL=http://localhost:8010/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
HF_TOKEN=

# Comma-separated origins allowed by CORS (defaults to http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# Directory containing simulation run data (defaults to ./runs)
SCHMIDT_RUNS_DIR=./runs

# Postgres connection string for the tenancy / runs index. Leave unset (or
# blank) for zero-setup no-database local mode: the runs index is derived from
# the filesystem and OAuth state is held in memory — no Postgres required.
# Set it to enable Postgres (required for Clerk multi-tenant auth / prod). See
# README "Local Postgres" for how to create a dev database.
# DATABASE_URL=postgresql://localhost:5432/schmidt_dev

# Clerk backend keys. Leave all unset for single-tenant local mode (every
# request runs as `local-user` in the `local` group). Set all four to enable
# Clerk-gated multi-tenant auth. See README "Authentication" for the JWT
# template and webhook setup.
# CLERK_SECRET_KEY=sk_test_...
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# CLERK_WEBHOOK_SECRET=whsec_...
# Comma-separated list of frontend origins allowed to mint Clerk tokens for
# this backend (e.g. http://localhost:3000,https://app.example.com).
# CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Public backend URL for MCP OAuth (MCP endpoint is disabled if unset).
# OAUTH_ISSUER_URL=http://localhost:8000

# Base URL of the frontend, used as the redirect target for the Clerk-gated
# MCP consent page (`{FRONTEND_URL}/mcp-consent?request_id=...`). When unset,
# falls back to the first entry of ALLOWED_ORIGINS (default
# http://localhost:3000).
# FRONTEND_URL=http://localhost:3000

# Stdlib logging level for `schmidt` CLI commands and the analysis scripts.
# Set to DEBUG to capture verbatim LLM-judge prompts and structured outputs
# in stderr (recommended when auditing the communication-feature pipeline).
# Defaults to INFO when unset.
# LOG_LEVEL=INFO

# Per-call output-token cap shared by all LLM providers (Claude max_tokens,
# OpenAI max_output_tokens, HuggingFace max_tokens). The default (16384) is
# enough for the verbose communication-feature judge outputs. Bump higher if
# you see truncated structured-output JSON; lower it to save cost on terse
# metrics.
# LLM_MAX_TOKENS=16384

# Self-hosted OpenAI-compatible LLM endpoints (used by `--provider self-hosted`).
# JSON map of model name → /v1 base URL. Add an entry for each deployed model
# (Modal, RunPod, local vLLM, etc.). The frontend reads this to populate the
# self-hosted model dropdown — no code change needed when adding a new model.
# SELF_HOSTED_BASE_URLS={"meta-llama/Llama-3.3-70B-Instruct":"https://<workspace>--llama-3-3-70b-instruct-serve.modal.run/v1","Qwen/Qwen3-32B":"https://<workspace>--qwen-3-32b-serve.modal.run/v1"}
# SELF_HOSTED_API_KEY=
