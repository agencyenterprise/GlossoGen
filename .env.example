# LLM provider keys (at least one required for running simulations)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local inference configuration. See docs/local-inference-vllm-mlx.md for setup instructions.
# OPENAI_BASE_URL=http://localhost:8010/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
HF_TOKEN=

# Shared password for web UI authentication (leave empty to disable auth)
APP_PASSWORD=

# Comma-separated origins allowed by CORS (defaults to http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# Directory containing simulation run data (defaults to ./runs)
SCHMIDT_RUNS_DIR=./runs
